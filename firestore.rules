rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar para verificar se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Função auxiliar para verificar se o usuário é o dono do documento (suporta UID ou e-mail como chave)
    function isOwner(userId) {
      return isAuthenticated() && (
        request.auth.uid == userId || 
        (request.auth.token.email != null && request.auth.token.email.lower() == userId.lower())
      );
    }

    // Função auxiliar para verificar se o usuário logado possui a role 'admin'
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email != null && (request.auth.token.email.lower() == 'vitorhugonascimentosique@gmail.com' || request.auth.token.email.lower() == 'henriquetranssilva@gmail.com')) ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email != null && exists(/databases/$(database)/documents/usuarios/$(request.auth.token.email.lower())) && get(/databases/$(database)/documents/usuarios/$(request.auth.token.email.lower())).data.role == 'admin')
      );
    }

    // Regras para a Coleção de Usuários
    match /usuarios/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Qualquer usuário pode se cadastrar (criar seu perfil)
      allow create: if isAuthenticated();
      // Dono pode editar dados (exceto role, a menos que seja admin)
      allow update: if isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || isAdmin());
      allow delete: if isAdmin();
    }

    // Regras para a Coleção de Ingressos
    match /ingressos/{ticketId} {
      // Usuário pode ler seus próprios ingressos, admin lê todos
      allow read: if (isAuthenticated() && resource.data.uid == request.auth.uid) || isAdmin();
      // Permitir criação no checkout ou por admin
      allow create: if (isAuthenticated() && request.resource.data.uid == request.auth.uid) || isAdmin();
      // Atualizações de status do ingresso (checkout/webhook/auditoria) permitidas para admin
      allow update, delete: if isAdmin();
    }

    // Regras para a Coleção de Sorteios
    match /sorteios/{sorteioId} {
      // Qualquer usuário (mesmo deslogado) pode ver a lista de sorteios e resultados
      allow read: if true;
      // Administradores gerenciam a criação e sorteio
      allow create, delete: if isAdmin();
      // Usuários autenticados podem participar (adicionar seu UID ao array de participantes)
      allow update: if isAuthenticated() || isAdmin();
    }

    // Regras para Coleção de Métricas
    match /metricas/{metricId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regras para Coleção de Configurações
    match /configuracoes/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
